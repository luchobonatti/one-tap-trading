# ===========================================
# One Tap Trading — Environment Variables
# ===========================================
# Single source of truth for all workspaces (web, indexer, contracts).
#
# Setup:
#   cp .env.example .env    # fill in values
#   pnpm setup              # symlinks packages/contracts/.env → this file
#
# NEVER commit .env — only .env.example is tracked.

# ------ Blockchain ------
# MegaETH Carrot testnet RPC
MEGAETH_RPC_URL=https://carrot.megaeth.com/rpc
# Chain ID (6343 = MegaETH testnet)
NEXT_PUBLIC_CHAIN_ID=6343

# ------ Oracle ------
# RedStone Bolt price feed contract address
REDSTONE_FEED_ADDRESS=

# ------ Indexer ------
# Port for the Rust Axum backend
INDEXER_PORT=3001
# HTTP base URL for REST API (indexer → frontend)
NEXT_PUBLIC_INDEXER_URL=http://localhost:3001
# WebSocket URL for price streaming (added in Phase 4)
# NEXT_PUBLIC_INDEXER_WS_URL=ws://localhost:3001/ws

# ------ Contracts ------
# Deployer private key (testnet only — NEVER use mainnet keys)
DEPLOYER_PRIVATE_KEY=
# Deployed contract addresses — MegaETH Carrot (chain ID 6343)
# Full list also in packages/contracts/deployments/6343.json
NEXT_PUBLIC_MOCK_USDC_ADDRESS=0xBD2e92B39081A9Dc541A776b5D7B7e0051851CCB
NEXT_PUBLIC_MOCK_PRICE_FEED_ADDRESS=0xd152AaBf6e4dA27004dC4a4B29da4a7754318469
NEXT_PUBLIC_PRICE_ORACLE_ADDRESS=0x7FBe2a83113A6374964d6fe25C000402471079d4
NEXT_PUBLIC_SETTLEMENT_ADDRESS=0x24354D1022E13f39f330Bbf2210edEEd21422eD5
NEXT_PUBLIC_PERP_ENGINE_ADDRESS=0xe35486669A5D905CF18D4af477Aaac08dF93Eab0
NEXT_PUBLIC_PAYMASTER_ADDRESS=

# ERC-4337 AA Infrastructure — MegaETH Carrot (chain 6343)
NEXT_PUBLIC_ENTRY_POINT_ADDRESS=0x0000000071727De22E5E9d8BAf0edAc6f37da032
# Self-hosted Alto bundler (see tools/alto/README.md for setup)
# Local dev: run Alto with tools/alto/megaeth-carrot.json
NEXT_PUBLIC_BUNDLER_RPC_URL=http://localhost:4337
# Alto pre-deployed simulation contracts (DO NOT redeploy — already on chain)
ALTO_EP_SIMULATIONS_V7=0x097219E615B5042095A707797fc30d67DbD58045
ALTO_PIMLICO_SIMULATIONS=0xf64BddD711a41aA281a00Ff5D90aa0aB59014402

# ------ Tooling ------
# Rust log level (trace, debug, info, warn, error)
RUST_LOG=info
# Foundry profile (default, ci, test)
FOUNDRY_PROFILE=default
